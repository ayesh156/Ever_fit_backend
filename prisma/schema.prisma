generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  role      Role     @default(CUSTOMER)
  orders    Order[]
  createdAt DateTime @default(now())

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  image       String?   @db.LongText
  status      String    @default("active")
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("categories")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  imageData String   @db.LongText
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  description String?          @db.Text
  price       Float
  image       String?          @db.LongText
  categoryId  Int
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  reviews     Review[]
  images      ProductImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("products")
}

model ProductVariant {
  id         Int         @id @default(autoincrement())
  productId  Int
  product    Product     @relation(fields: [productId], references: [id])
  size       String
  color      String
  sku        String      @unique
  barcode    String?     @unique
  stock      Int         @default(0)
  orderItems OrderItem[]

  @@map("product_variants")
}

model Review {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  reviewerName  String
  reviewerPhoto String?  @db.LongText
  description   String?  @db.Text
  rating        Int      @default(5)
  createdAt     DateTime @default(now())

  @@map("reviews")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  PENDING_RECEIPT
  PAYMENT_REVIEW
  PAYMENT_VERIFIED
  PROCESSING
  SHIPPED
  DELIVERED
}

model Order {
  id            Int            @id @default(autoincrement())
  userId        Int?
  user          User?          @relation(fields: [userId], references: [id])
  customerName  String?
  customerPhone String?
  totalAmount   Float
  subtotal      Float          @default(0)
  discount      Float          @default(0)
  paidAmount    Float          @default(0)
  dueDate       DateTime?
  status              OrderStatus    @default(PENDING_RECEIPT)
  paymentMethod       String?
  paymentReceiptUrl   String?
  notes               String?  @db.Text
  payments            OrderPayment[]
  items               OrderItem[]
  createdAt     DateTime       @default(now())

  @@map("orders")
}

model OrderPayment {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Float
  method    String
  reference String?
  createdAt DateTime @default(now())

  @@map("order_payments")
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("subscribers")
}

model StorefrontSetting {
  key       String   @id
  value     String   @db.LongText
  updatedAt DateTime @updatedAt

  @@map("storefront_settings")
}

model OrderItem {
  id        Int            @id @default(autoincrement())
  orderId   Int
  order     Order          @relation(fields: [orderId], references: [id])
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Float
  discount  Float          @default(0)
  price     Float

  @@map("order_items")
}
